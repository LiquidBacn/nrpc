{
  "include": [
    "./src/server/index.ts",
    "./src/client/index.ts",
    "./src/shared/index.ts"
  ],
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "declaration": true,
    "strictNullChecks": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "outDir": "./dist",
    "types": [
      "vite/client"
    ],
  },
  "exclude": [
    "node_modules"
  ]
}
