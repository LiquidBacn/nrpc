{
  "name": "@bvklive/nrpc",
  "version": "0.0.0",
  "description": "Hackable typed RPC",
  "license": "MIT",
  "author": "BVK",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiquidBacn/nrpc.git"
  },
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "require": "./dist/server/index.cjs",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "require": "./dist/client/index.cjs",
      "import": "./dist/client/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "require": "./dist/shared/index.cjs",
      "import": "./dist/shared/index.js"
    },
    "./shared/*": "./dist/shared/*",
    "./balancer": {
      "types": "./dist/balancer/index.d.ts",
      "require": "./dist/balancer/index.cjs",
      "import": "./dist/balancer/index.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "prettier": {
    "experimentalTernaries": true
  }
}
